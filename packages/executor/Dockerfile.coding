# Executor + Node.js — supports on-demand CLI installation.
# The gateway's backend setup (npm install -g @google/gemini-cli etc.)
# runs on first turn. ~200MB base, CLIs installed at runtime.
FROM node:22-slim

# Install the Go executor binary
COPY --from=golang:1.26-alpine /usr/local/go /usr/local/go
ENV PATH="/usr/local/go/bin:${PATH}"

WORKDIR /build
COPY go.mod main.go ./
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /usr/local/bin/executor . && rm -rf /build /usr/local/go

# Basic tools needed by agent CLIs
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates bash \
    && rm -rf /var/lib/apt/lists/*

# Create agent user (non-root)
RUN useradd -m -s /bin/bash agent
USER agent
WORKDIR /home/agent

# npm global prefix for non-root installs
ENV NPM_CONFIG_PREFIX=/home/agent/.npm-global
ENV PATH="/home/agent/.npm-global/bin:${PATH}"

ENV EXECUTOR_PORT=8080
EXPOSE 8080

ENTRYPOINT ["executor"]
